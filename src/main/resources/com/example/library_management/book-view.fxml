<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.library_management.controller.BookController">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18" />
    </padding>

    <Label text="Library Management System" style="-fx-font-size: 22px; -fx-font-weight: bold;" />

    <GridPane hgap="12" vgap="12">
        <columnConstraints>
            <ColumnConstraints percentWidth="16" />
            <ColumnConstraints percentWidth="34" />
            <ColumnConstraints percentWidth="16" />
            <ColumnConstraints percentWidth="34" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
        </rowConstraints>

        <Label text="ID" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="idField" editable="false" promptText="Auto-generated"
                   GridPane.rowIndex="0" GridPane.columnIndex="1" />
        <Label text="ISBN" GridPane.rowIndex="0" GridPane.columnIndex="2" />
        <TextField fx:id="isbnField" promptText="978-0-00-000000-0"
                   GridPane.rowIndex="0" GridPane.columnIndex="3" />

        <Label text="Title" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <TextField fx:id="titleField" promptText="Book title"
                   GridPane.rowIndex="1" GridPane.columnIndex="1" />
        <Label text="Author" GridPane.rowIndex="1" GridPane.columnIndex="2" />
        <TextField fx:id="authorField" promptText="First Last"
                   GridPane.rowIndex="1" GridPane.columnIndex="3" />

        <Label text="Genre" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <ComboBox fx:id="genreComboBox" promptText="Select genre"
                  GridPane.rowIndex="2" GridPane.columnIndex="1" />
        <Label text="Year Published" GridPane.rowIndex="2" GridPane.columnIndex="2" />
        <TextField fx:id="publishedYearField" promptText="2024"
                   GridPane.rowIndex="2" GridPane.columnIndex="3" />

        <Label text="Total Copies" GridPane.rowIndex="3" GridPane.columnIndex="0" />
        <TextField fx:id="totalCopiesField" promptText="1"
                   GridPane.rowIndex="3" GridPane.columnIndex="1" />
        <Label text="Available" GridPane.rowIndex="3" GridPane.columnIndex="2" />
        <TextField fx:id="availableCopiesField" promptText="1"
                   GridPane.rowIndex="3" GridPane.columnIndex="3" />
    </GridPane>

    <HBox spacing="10">
        <Button text="Add" onAction="#handleAdd" />
        <Button text="Update" onAction="#handleUpdate" />
        <Button text="Delete" onAction="#handleDelete" />
        <Button text="Clear" onAction="#handleClear" />
    </HBox>

    <TableView fx:id="bookTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="50" />
            <TableColumn fx:id="isbnColumn" text="ISBN" prefWidth="160" />
            <TableColumn fx:id="titleColumn" text="Title" prefWidth="200" />
            <TableColumn fx:id="authorColumn" text="Author" prefWidth="160" />
            <TableColumn fx:id="genreColumn" text="Genre" prefWidth="120" />
            <TableColumn fx:id="publishedYearColumn" text="Year" prefWidth="70" />
            <TableColumn fx:id="totalCopiesColumn" text="Total" prefWidth="70" />
            <TableColumn fx:id="availableCopiesColumn" text="Available" prefWidth="90" />
        </columns>
    </TableView>

    <Pagination fx:id="bookPagination" pageCount="1" maxPageIndicatorCount="5" />
</VBox>
